{
  "manifest_version": 3,
  "name": "社交平台中文转英文翻译助手",
  "version": "1.0",
  "description": "在 X、Twitter 和 Reddit 上发帖或回复时，自动将中文翻译为英文",
  "permissions": ["activeTab", "storage"],
  "host_permissions": [
    "https://x.com/*",
    "https://twitter.com/*",
    "https://www.reddit.com/*",
    "https://reddit.com/*",
    "https://api.anthropic.com/*",
    "https://api.siliconflow.cn/*",
    "https://api.deepseek.com/*",
    "https://dashscope.aliyuncs.com/*",
    "https://*/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://x.com/*",
        "https://twitter.com/*",
        "https://www.reddit.com/*",
        "https://reddit.com/*"
      ],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["styles.css"],
      "matches": ["https://www.reddit.com/*", "https://reddit.com/*"]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  }
}
